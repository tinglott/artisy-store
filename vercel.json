{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/flipbooks/(.*)\\.html$",
      "dest": "/flipbooks/$1.html",
      "methods": ["GET"],
      "continue": true
    },
    {
      "src": "/(.*)\\.html$",
      "dest": "/$1.html",
      "methods": ["GET"],
      "continue": true
    }
  ],
  "redirects": [
    {
      "source": "/safari-clue-seekers",
      "destination": "/safari-clue-seekers/index.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/flipbooks/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/ping-n8n",
      "schedule": "0 0 * * *"
    }
  ]
}
