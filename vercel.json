{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/safari-clue-seekers",
      "destination": "/safari-clue-seekers/index.html"
    },
    {
      "source": "/safari-clue-seekers/:path*",
      "destination": "/safari-clue-seekers/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/ping-n8n",
      "schedule": "*/5 * * * *"
    }
  ]
}
